# ThreadSanitizer suppressions for libquicr integration tests.
#
# Used by setting TSAN_OPTIONS=suppressions=<this file> when running the
# quicr_integration_test binary. Scope is intentionally narrow: only known
# upstream picoquic noise is suppressed. Anything in libquicr (including
# transport_picoquic.cpp glue) must remain visible so that real races are
# not hidden.

# picoquic exposes thread_is_ready / return_code as `volatile int` and the
# main thread spins on them while the network thread sets them. Benign on
# every platform libquicr supports (aligned 4-byte stores are atomic on
# arm64/x86), but TSan flags it because they aren't std::atomic.
race:picoquic_packet_loop_v3
race:picoquic_packet_loop_poll

# picoquic_delete_network_thread writes the same flags during shutdown.
race:picoquic_delete_network_thread

# picoquic seeds a global RNG / TLS context once. The seeding writes are
# guarded by picoquic's own startup ordering; TSan can't see that.
race:picoquic_master_tlscontext
race:picoquic_public_random_seed_64
